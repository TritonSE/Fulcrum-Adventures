# Copy to .env and adjust. Never commit .env.

# MongoDB Atlas — copy connection string from Connect → Drivers; use database fulcrum_prod
# MONGODB_URI=<paste Atlas connection string here>

# Required for admin auth tokens (generate with: openssl rand -base64 32)
JWT_SECRET=replace-with-a-long-random-string

# Optional (default 7d)
# JWT_EXPIRES_IN=7d

# Optional (default 4000)
# PORT=4000

# Optional CORS (admin local dev)
# FRONTEND_ORIGIN=http://localhost:5173
